# ═══════════════════════════════════════════
# AgentZero Bridge Configuration
# ═══════════════════════════════════════════

# ── Account ──
# Deployer private key (used for both Base and GenLayer)
PRIVATE_KEY=your_private_key_here

# ── GenLayer ──
GENLAYER_RPC_URL=https://studio.genlayer.com/api

# GenLayer bridge infrastructure (deployed from /smart-contracts)
GL_BRIDGE_SENDER_ADDRESS=
BRIDGE_RECEIVER_IC_ADDRESS=

# AgentZeroBrain IC address on GenLayer (deployed from /example)
GENLAYER_BRAIN_ADDRESS=

# ── Base Sepolia ──
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Base bridge infrastructure (deployed from /smart-contracts)
BRIDGE_SENDER_ADDRESS=
BRIDGE_RECEIVER_ADDRESS=

# AgentZeroBase contract on Base (deployed from /example/smart-contracts)
AGENT_ZERO_BASE_ADDRESS=

# ── ZKsync Era Sepolia (Hub) ──
ZKSYNC_SEPOLIA_RPC_URL=https://sepolia.era.zksync.dev

# Hub contracts (deployed from /smart-contracts)
ZKSYNC_BRIDGE_RECEIVER_ADDRESS=
ZKSYNC_BRIDGE_FORWARDER_ADDRESS=
